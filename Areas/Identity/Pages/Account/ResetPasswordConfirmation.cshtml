@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Contraseña Restablecida";
    Layout = "_Layout";
}

<!-- Reset Password Confirmation Section -->
<div class="auth-container-modern">
    <div class="container-fluid h-100">
        <div class="row h-100 align-items-center justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="auth-card-confirmation">
                    <div class="auth-card-body text-center">
                        <!-- Success Icon -->
                        <div class="auth-status-icon mb-4">
                            <div class="auth-success-icon">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                        </div>

                        <!-- Title -->
                        <h1 class="auth-title-confirmation mb-4">
                            <span>¡Contraseña Restablecida!</span>
                        </h1>

                        <!-- Success Message -->
                        <div class="auth-message-card success mb-4">
                            <div class="auth-message-content">
                                <h5 class="mb-3">Tu contraseña ha sido actualizada exitosamente</h5>
                                <p class="mb-3">Ya puedes iniciar sesión con tu nueva contraseña en VitalCare.</p>
                                <div class="auth-email-highlight">
                                    <i class="bi bi-shield-check me-2"></i>
                                    <strong>Tu cuenta está segura</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Security Info -->
                        <div class="auth-instructions mb-4">
                            <div class="row text-start">
                                <div class="col-md-6 mb-3">
                                    <div class="auth-instruction-item">
                                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                                        <span>Contraseña actualizada</span>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="auth-instruction-item">
                                        <i class="bi bi-shield-lock-fill text-success me-2"></i>
                                        <span>Sesiones cerradas por seguridad</span>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="auth-instruction-item">
                                        <i class="bi bi-key-fill text-success me-2"></i>
                                        <span>Nueva clave activa</span>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="auth-instruction-item">
                                        <i class="bi bi-person-check-fill text-success me-2"></i>
                                        <span>Cuenta protegida</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="auth-confirmation-actions mb-4">
                            <a asp-page="./Login" class="auth-btn-primary auth-btn-large me-3">
                                <i class="bi bi-box-arrow-in-right me-2"></i>
                                Iniciar Sesión
                            </a>
                            <a asp-page="/Index" class="auth-btn-secondary auth-btn-large">
                                <i class="bi bi-house me-2"></i>
                                Ir al Inicio
                            </a>
                        </div>

                        <!-- Security Tips -->
                        <div class="auth-help-section">
                            <details class="auth-details">
                                <summary>Consejos de seguridad</summary>
                                <div class="auth-help-content mt-3">
                                    <ul class="list-unstyled text-start">
                                        <li><i class="bi bi-shield-check me-2"></i>Mantén tu contraseña segura y no la compartas</li>
                                        <li><i class="bi bi-eye-slash me-2"></i>Usa una contraseña única para VitalCare</li>
                                        <li><i class="bi bi-clock me-2"></i>Cambia tu contraseña periódicamente</li>
                                        <li><i class="bi bi-exclamation-triangle me-2"></i>Reporta cualquier actividad sospechosa</li>
                                    </ul>
                                </div>
                            </details>
                        </div>

                        <!-- Additional Info -->
                        <div class="auth-additional-info mt-5">
                            <small class="text-muted">
                                <i class="bi bi-shield-fill-check me-1"></i>
                                VitalCare mantiene tu información segura y protegida
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
