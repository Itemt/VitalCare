@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = "_Layout";
}

<!-- Forgot Password Section -->
<div class="auth-page-wrapper">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <i class="bi bi-heart-pulse"></i>
                </div>
                <h1 class="auth-title">¿Olvidaste tu contraseña?</h1>
                <p class="auth-subtitle">
                    No te preocupes, te ayudamos a recuperarla. Ingresa tu correo electrónico y te enviaremos un enlace para restablecer tu contraseña.
                </p>
            </div>

            <form method="post" class="auth-form" id="forgotPasswordForm">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>
                
                <!-- Email Input -->
                <div class="auth-form-floating">
                    <i class="auth-form-icon bi bi-envelope-fill"></i>
                    <input asp-for="Input.Email" 
                           class="auth-form-control" 
                           autocomplete="username" 
                           aria-required="true" 
                           placeholder=" " 
                           type="text"
                           id="emailInput" />
                    <label asp-for="Input.Email" class="auth-form-label">Correo Electrónico</label>
                    <span asp-validation-for="Input.Email" class="auth-validation-error"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="auth-btn-primary" id="forgotPasswordSubmit">
                    <i class="bi bi-arrow-clockwise me-2"></i>
                    Enviar Enlace de Recuperación
                </button>

                <!-- Auth Links -->
                <div class="auth-links">
                    <div>
                        <a asp-page="./Login" class="auth-link">
                            <i class="bi bi-arrow-left me-1"></i>
                            Volver a Iniciar Sesión
                        </a>
                    </div>
                    <div>
                        <a asp-page="./Register" class="auth-link">
                            <i class="bi bi-person-plus me-1"></i>
                            ¿No tienes cuenta? Regístrate
                        </a>
                    </div>
                </div>
            </form>

            <!-- Help Section -->
            <div class="auth-help-section mt-4">
                <details class="auth-details">
                    <summary>¿Necesitas ayuda?</summary>
                    <div class="auth-help-content mt-3">
                        <ul class="list-unstyled text-start">
                            <li><i class="bi bi-check2 me-2"></i>Asegúrate de ingresar el correo con el que te registraste</li>
                            <li><i class="bi bi-check2 me-2"></i>Revisa tu carpeta de spam si no recibes el correo</li>
                            <li><i class="bi bi-check2 me-2"></i>El enlace de recuperación expira en 24 horas</li>
                            <li><i class="bi bi-check2 me-2"></i>Si persisten los problemas, contacta al soporte</li>
                        </ul>
                    </div>
                </details>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Loading state for submit button
        document.getElementById('forgotPasswordForm').addEventListener('submit', function() {
            const submitBtn = document.getElementById('forgotPasswordSubmit');
            submitBtn.classList.add('auth-btn-loading');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-2"></i>Enviando...';
        });
    </script>
}
