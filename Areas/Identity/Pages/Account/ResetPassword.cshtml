@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Nueva Contraseña";
    Layout = "_Layout";
}

<!-- Reset Password Section -->
<div class="auth-page-wrapper">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h1 class="auth-title">Crear Nueva Contraseña</h1>
                <p class="auth-subtitle">
                    Estás a un paso de recuperar tu cuenta. Crea una nueva contraseña segura para tu cuenta de VitalCare.
                </p>
            </div>

            <form method="post" class="auth-form" id="resetPasswordForm">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>
                <input asp-for="Input.Code" type="hidden" />
                
                <!-- Email Input (readonly) -->
                <div class="auth-form-floating">
                    <i class="auth-form-icon bi bi-envelope-fill"></i>
                    <input asp-for="Input.Email" 
                           class="auth-form-control" 
                           autocomplete="username" 
                           aria-required="true" 
                           placeholder=" " 
                           type="text"
                           readonly />
                    <label asp-for="Input.Email" class="auth-form-label">Correo Electrónico</label>
                    <span asp-validation-for="Input.Email" class="auth-validation-error"></span>
                </div>

                <!-- Password Input -->
                <div class="auth-form-floating">
                    <i class="auth-form-icon bi bi-lock-fill"></i>
                    <input asp-for="Input.Password" 
                           class="auth-form-control" 
                           autocomplete="new-password" 
                           aria-required="true" 
                           placeholder=" " 
                           type="password"
                           id="newPasswordInput" />
                    <label asp-for="Input.Password" class="auth-form-label">Nueva Contraseña</label>
                    <button type="button" class="password-toggle" id="toggleNewPassword">
                        <i class="bi bi-eye-slash"></i>
                    </button>
                    <span asp-validation-for="Input.Password" class="auth-validation-error"></span>
                </div>

                <!-- Confirm Password Input -->
                <div class="auth-form-floating">
                    <i class="auth-form-icon bi bi-shield-lock-fill"></i>
                    <input asp-for="Input.ConfirmPassword" 
                           class="auth-form-control" 
                           autocomplete="new-password" 
                           aria-required="true" 
                           placeholder=" " 
                           type="password"
                           id="confirmNewPasswordInput" />
                    <label asp-for="Input.ConfirmPassword" class="auth-form-label">Confirmar Nueva Contraseña</label>
                    <button type="button" class="password-toggle" id="toggleConfirmNewPassword">
                        <i class="bi bi-eye-slash"></i>
                    </button>
                    <span asp-validation-for="Input.ConfirmPassword" class="auth-validation-error"></span>
                </div>

                <!-- Password Requirements -->
                <div class="auth-password-requirements mb-3">
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        La contraseña debe tener al menos 4 caracteres
                    </small>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="auth-btn-primary" id="resetPasswordSubmit">
                    <i class="bi bi-check-circle me-2"></i>
                    Restablecer Contraseña
                </button>

                <!-- Auth Links -->
                <div class="auth-links">
                    <div class="text-center">
                        <a asp-page="./Login" class="auth-link">
                            <i class="bi bi-arrow-left me-1"></i>
                            Volver a Iniciar Sesión
                        </a>
                    </div>
                </div>
            </form>

            <!-- Security Notice -->
            <div class="auth-security-notice mt-4">
                <div class="d-flex align-items-start">
                    <i class="bi bi-shield-check text-success me-2 mt-1"></i>
                    <small class="text-muted">
                        <strong>Nota de seguridad:</strong> Una vez que restablezcas tu contraseña, se cerrarán todas las sesiones activas en otros dispositivos para proteger tu cuenta.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/password-toggle.js"></script>
    <script>
        // Password toggle functionality for reset password page
        const toggleNewButton = document.getElementById('toggleNewPassword');
        const toggleConfirmNewButton = document.getElementById('toggleConfirmNewPassword');
        const newPasswordInput = document.getElementById('newPasswordInput');
        const confirmNewPasswordInput = document.getElementById('confirmNewPasswordInput');
        
        // Toggle for new password
        if (toggleNewButton && newPasswordInput) {
            toggleNewButton.addEventListener('click', function(e) {
                e.preventDefault();
                const icon = this.querySelector('i');
                
                if (newPasswordInput.type === 'password') {
                    newPasswordInput.type = 'text';
                    icon.className = 'bi bi-eye';
                } else {
                    newPasswordInput.type = 'password';
                    icon.className = 'bi bi-eye-slash';
                }
            });
        }

        // Toggle for confirm new password
        if (toggleConfirmNewButton && confirmNewPasswordInput) {
            toggleConfirmNewButton.addEventListener('click', function(e) {
                e.preventDefault();
                const icon = this.querySelector('i');
                
                if (confirmNewPasswordInput.type === 'password') {
                    confirmNewPasswordInput.type = 'text';
                    icon.className = 'bi bi-eye';
                } else {
                    confirmNewPasswordInput.type = 'password';
                    icon.className = 'bi bi-eye-slash';
                }
            });
        }

        // Loading state for submit button
        document.getElementById('resetPasswordForm').addEventListener('submit', function() {
            const submitBtn = document.getElementById('resetPasswordSubmit');
            submitBtn.classList.add('auth-btn-loading');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Restableciendo...';
        });
    </script>
}
