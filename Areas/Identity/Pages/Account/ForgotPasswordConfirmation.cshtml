@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Solicitud Enviada";
    Layout = "_AuthLayout";
}

<!-- Forgot Password Confirmation Section -->
<div class="auth-container-modern">
    <div class="container-fluid h-100">
        <div class="row h-100 align-items-center justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="auth-card-confirmation">
                    <div class="auth-card-body text-center">
                        <!-- Email Icon -->
                        <div class="auth-status-icon mb-4">
                            <div class="auth-email-icon">
                                <i class="bi bi-envelope-paper-fill"></i>
                            </div>
                        </div>

                        <!-- Title -->
                        <h1 class="auth-title-confirmation mb-4">
                            <span>¡Solicitud Enviada!</span>
                        </h1>

                        <!-- Main Message -->
                        <div class="auth-message-card success mb-4">
                            <div class="auth-message-content">
                                <h5 class="mb-3">Revisa tu correo electrónico</h5>
                                <p class="mb-3">Hemos enviado un enlace para restablecer tu contraseña a tu dirección de correo electrónico.</p>
                                <div class="auth-email-highlight">
                                    <i class="bi bi-clock me-2"></i>
                                    <strong>El enlace expira en 24 horas</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Instructions -->
                        <div class="auth-instructions mb-4">
                            <div class="row text-start">
                                <div class="col-md-6 mb-3">
                                    <div class="auth-instruction-item">
                                        <i class="bi bi-1-circle-fill me-2"></i>
                                        <span>Revisa tu bandeja de entrada</span>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="auth-instruction-item">
                                        <i class="bi bi-2-circle-fill me-2"></i>
                                        <span>Busca el correo de VitalCare</span>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="auth-instruction-item">
                                        <i class="bi bi-3-circle-fill me-2"></i>
                                        <span>Haz clic en "Restablecer Contraseña"</span>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="auth-instruction-item">
                                        <i class="bi bi-4-circle-fill me-2"></i>
                                        <span>Crea tu nueva contraseña</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="auth-confirmation-actions mb-4">
                            <a asp-page="./ForgotPassword" class="auth-btn-primary auth-btn-large me-3">
                                <i class="bi bi-arrow-clockwise me-2"></i>
                                Reenviar Correo
                            </a>
                            <a asp-page="./Login" class="auth-btn-secondary auth-btn-large">
                                <i class="bi bi-box-arrow-in-right me-2"></i>
                                Volver a Iniciar Sesión
                            </a>
                        </div>

                        <!-- Additional Help -->
                        <div class="auth-help-section">
                            <details class="auth-details">
                                <summary>¿No recibiste el correo?</summary>
                                <div class="auth-help-content mt-3">
                                    <ul class="list-unstyled text-start">
                                        <li><i class="bi bi-check2 me-2"></i>Verifica que el correo esté escrito correctamente</li>
                                        <li><i class="bi bi-check2 me-2"></i>Revisa tu carpeta de spam o correo no deseado</li>
                                        <li><i class="bi bi-check2 me-2"></i>El correo puede tardar unos minutos en llegar</li>
                                        <li><i class="bi bi-check2 me-2"></i>Asegúrate de haber usado el correo de registro</li>
                                    </ul>
                                </div>
                            </details>
                        </div>

                        <!-- Additional Info -->
                        <div class="auth-additional-info mt-5">
                            <small class="text-muted">
                                <i class="bi bi-shield-check me-1"></i>
                                VitalCare protege tu información personal
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
