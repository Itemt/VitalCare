@page
@model IndexModel
@using Microsoft.AspNetCore.Identity
@using CitasEPS.Models
@inject SignInManager<User> UserManagerAccessor
@inject UserManager<User> AspNetUserManager

@{
    ViewData["Title"] = "Inicio - VitalCare";
    var currentUser = await AspNetUserManager.GetUserAsync(User);
    var userFirstName = currentUser?.FirstName;
    var isDoctor = User.IsInRole("Doctor");
    var isPatient = User.IsInRole("Paciente");
    var isLoggedIn = UserManagerAccessor.IsSignedIn(User);
}

@if (!isLoggedIn)
{
    <!-- Hero Section Moderno - Estilo Optimizado -->
    <section class="hero-modern mb-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="hero-content animate-fade-up text-center">
                        <h1 class="hero-title-gradient mb-4">
                            <span class="vital-text">Vital</span><span class="care-text">Care</span>
                        </h1>
                        <p class="lead text-white mb-5 fs-3">
                            Su salud es nuestra prioridad. Experimente la medicina del futuro 
                            con tecnología de vanguardia y atención personalizada.
                        </p>
                        
                        <!-- Estadísticas Compactas -->
                        <div class="row g-3 mt-4 mb-5">
                            <div class="col-md-4">
                                <div class="stats-card-modern">
                                    <div class="stats-number hero-element-with-sweep">
                                        25K+
                                        <div class="element-sweep"></div>
                                    </div>
                                    <h6 class="text-white-50">Pacientes Atendidos</h6>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="stats-card-modern">
                                    <div class="stats-number hero-element-with-sweep">
                                        350+
                                        <div class="element-sweep"></div>
                                    </div>
                                    <h6 class="text-white-50">Especialistas</h6>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="stats-card-modern">
                                    <div class="stats-number hero-element-with-sweep">
                                        98%
                                        <div class="element-sweep"></div>
                                    </div>
                                    <h6 class="text-white-50">Satisfacción</h6>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Botones de Acción -->
                        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center mb-4">
                            <a class="btn btn-hero btn-hero-login btn-lg px-4 py-2 me-sm-3 hero-element-with-sweep" asp-area="Identity" asp-page="/Account/Login" role="button">
                                <i class="bi bi-box-arrow-in-right me-2"></i>
                                <span>Iniciar Sesión</span>
                                <div class="element-sweep"></div>
                            </a>
                            <a class="btn btn-hero btn-hero-register btn-lg px-4 py-2 hero-element-with-sweep" asp-area="Identity" asp-page="/Account/Register" role="button">
                                <i class="bi bi-person-plus me-2"></i>
                                <span>Registrarse Gratis</span>
                                <div class="element-sweep"></div>
                            </a>
                        </div>
                        
                        <!-- Badges de Confianza -->
                        <div class="row g-3 mt-4">
                            <div class="col-md-4">
                                <div class="badge text-white p-3 fs-6 fw-bold hero-element-with-sweep" style="background: linear-gradient(135deg, #22c55e, #16a34a); box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);">
                                    <i class="bi bi-award-fill me-2"></i>ISO 27001 Certificado
                                    <div class="element-sweep"></div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="badge text-white p-3 fs-6 fw-bold hero-element-with-sweep" style="background: linear-gradient(135deg, #3b82f6, #2563eb); box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);">
                                    <i class="bi bi-shield-fill-check me-2"></i>HIPAA Compliant
                                    <div class="element-sweep"></div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="badge text-white p-3 fs-6 fw-bold hero-element-with-sweep" style="background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);">
                                    <i class="bi bi-patch-check-fill me-2"></i>SSL Protegido
                                    <div class="element-sweep"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
else if (isDoctor)
{
    <!-- Hero para Doctor con Imagen -->
    <div class="container-fluid text-center py-4 mb-4">
        <div class="row justify-content-center align-items-center">
            <div class="col-lg-6">
                <div class="doctor-welcome-content">
                    <h2 class="welcome-title mb-3 text-dark">
                        <i class="bi bi-clipboard-pulse me-2 text-primary"></i>
                        @if (!string.IsNullOrEmpty(userFirstName))
                        {
                            <span>Bienvenido Dr(a). <strong>@userFirstName</strong></span>
                        }
                        else
                        {
                            <span>Portal Médico</span>
                        }
                    </h2>
                    <p class="welcome-subtitle text-muted">Gestione su agenda, consulte pacientes y acceda a su panel profesional</p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="doctor-image-container">
                    <img src="~/images/doctor.png" alt="Portal Médico" class="img-fluid rounded-3 shadow-lg" style="max-height: 300px; width: auto;">
                </div>
            </div>
        </div>
    </div>
}
else if (isPatient)
{
    <!-- Hero para Paciente con Imagen -->
    <div class="container-fluid text-center py-4 mb-4">
        <div class="row justify-content-center align-items-center">
            <div class="col-lg-6">
                <div class="patient-welcome-content">
                    <h2 class="welcome-title mb-3 text-dark">
                        <i class="bi bi-person-heart me-2 text-success"></i>
                        @if (!string.IsNullOrEmpty(userFirstName))
                        {
                            <span>Bienvenido <strong>@userFirstName</strong></span>
                        }
                        else
                        {
                            <span>Portal del Paciente</span>
                        }
                    </h2>
                    <p class="welcome-subtitle text-muted">Aquí puede gestionar sus citas y consultar su información médica</p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="patient-image-container">
                    <img src="~/images/Pacientes.png" alt="Portal del Paciente" class="img-fluid rounded-3 shadow-lg" style="max-height: 300px; width: auto;">
                </div>
            </div>
        </div>
    </div>
}

<!-- Main Content Section - Dynamic based on Role -->
<div class="container mt-5 py-2">
    @if (UserManagerAccessor.IsSignedIn(User))
    {
        @if (User.IsInRole("Admin"))
        {
            <div id="adminPanelDashboard" class="row justify-content-center">
                <div class="col-lg-10 col-xl-9">
                    <div class="card shadow-lg modern-card-hover">
                        <div class="card-header bg-primary text-white text-center">
                            <h2 class="my-2"><i class="bi bi-person-gear"></i> Panel de Administración</h2>
                        </div>
                        <div class="card-body p-4">
                            <p class="lead text-center mb-4">Gestione las entidades clave y configuraciones del sistema.</p>
                            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                                <div class="col">
                                    <div class="card h-100 shadow-lg border-primary action-card-hover feature-card-hover rainbow-card">
                                        <div class="card-body d-flex flex-column align-items-center">
                                            <div class="feature-icon-wrapper mb-3">
                                                <i class="bi bi-people-fill fs-1 text-primary feature-icon-main rotating-icon"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                    <span class="sparkle sparkle-4"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Usuarios</h5>
                                            <p class="card-text flex-grow-1">Administrar cuentas de todos los usuarios.</p>
                                            <a asp-page="/Admin/ManageUsers" class="btn btn-primary mt-auto w-100"><i class="bi bi-arrow-right-circle"></i> Ir</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="card h-100 shadow-lg border-primary action-card-hover feature-card-hover rainbow-card">
                                        <div class="card-body d-flex flex-column align-items-center">
                                            <div class="feature-icon-wrapper mb-3">
                                                <i class="bi bi-calendar-check-fill fs-1 text-primary feature-icon-main"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Citas</h5>
                                            <p class="card-text flex-grow-1">Ver y administrar todas las citas.</p>
                                            <a asp-page="/Admin/ManageAppointments" class="btn btn-primary mt-auto w-100"><i class="bi bi-arrow-right-circle"></i> Ir</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="card h-100 shadow-lg border-primary action-card-hover feature-card-hover rainbow-card">
                                        <div class="card-body d-flex flex-column align-items-center">
                                            <div class="feature-icon-wrapper mb-3">
                                                <i class="bi bi-file-medical-fill fs-1 text-primary feature-icon-main"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Médicos</h5>
                                            <p class="card-text flex-grow-1">Gestionar perfiles de médicos.</p>
                                            <a asp-page="/Admin/ManageDoctors" class="btn btn-primary mt-auto w-100"><i class="bi bi-arrow-right-circle"></i> Ir</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="card h-100 shadow-lg border-primary action-card-hover feature-card-hover rainbow-card">
                                        <div class="card-body d-flex flex-column align-items-center">
                                            <div class="feature-icon-wrapper mb-3">
                                                <i class="bi bi-bookmark-star-fill fs-1 text-primary feature-icon-main"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Especialidades</h5>
                                            <p class="card-text flex-grow-1">Añadir o editar especialidades.</p>
                                            <a asp-page="/Admin/ManageSpecialties" class="btn btn-primary mt-auto w-100"><i class="bi bi-arrow-right-circle"></i> Ir</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="card h-100 shadow-lg border-primary action-card-hover feature-card-hover rainbow-card">
                                        <div class="card-body d-flex flex-column align-items-center">
                                            <div class="feature-icon-wrapper mb-3 mx-auto">
                                                <i class="bi bi-capsule fs-1 feature-icon-main" style="color: #0f172a;"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Medicamentos</h5>
                                            <p class="card-text flex-grow-1">Gestionar listado de medicamentos.</p>
                                            <a asp-page="/Admin/Medications/Index" class="btn btn-primary mt-auto w-100"><i class="bi bi-arrow-right-circle"></i> Ir</a>
                                        </div>
                                    </div>
                                </div>
                                 <div class="col">
                                    <div class="card h-100 shadow-lg border-secondary action-card-hover feature-card-hover rainbow-card">
                                        <div class="card-body d-flex flex-column align-items-center">
                                            <div class="feature-icon-wrapper mb-3">
                                                <i class="bi bi-person-lines-fill fs-1 text-secondary feature-icon-main"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Pacientes</h5>
                                            <p class="card-text flex-grow-1">Administrar información de pacientes.</p>
                                            <a asp-page="/Admin/ManagePatients" class="btn btn-outline-secondary mt-auto w-100"><i class="bi bi-arrow-right-circle"></i> Ir</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Trust Indicators for Admin -->
                        <div class="card-footer bg-light text-center">
                            <div class="row align-items-center text-muted">
                                <div class="col-md-3 mb-2 mb-md-0">
                                    <i class="bi bi-award-fill fs-5 text-warning"></i>
                                    <div class="small">Certificado ISO 9001</div>
                                </div>
                                <div class="col-md-3 mb-2 mb-md-0">
                                    <i class="bi bi-shield-check fs-5 text-success"></i>
                                    <div class="small">Ministerio de Salud</div>
                                </div>
                                <div class="col-md-3 mb-2 mb-md-0">
                                    <i class="bi bi-star-fill fs-5 text-info"></i>
                                    <div class="small">Premio Innovación 2024</div>
                                </div>
                                <div class="col-md-3">
                                    <i class="bi bi-globe fs-5 text-primary"></i>
                                    <div class="small">Red Internacional</div>
                                </div>
                            </div>
                            <p class="mb-0 text-muted small mt-2">Panel de Control Administrativo - Reconocido por Instituciones Líderes</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (User.IsInRole("Doctor"))
        {
            <div id="doctorPanelDashboard" class="row justify-content-center">
                <div class="col-lg-10 col-xl-9">
                    <div class="card shadow-lg modern-card-hover">
                        <div class="card-header bg-info text-white text-center text-shadow-custom">
                            <h2 class="my-2"><i class="bi bi-clipboard-pulse"></i> Portal Médico</h2>
                        </div>
                        <div class="card-body p-4">
                            @if (!string.IsNullOrEmpty(userFirstName))
                            {
                                <p class="lead text-center mb-4">Bienvenido Dr(a). <span class="fw-semibold">@userFirstName</span>. Acceda a su agenda y gestione pacientes.</p>
                            } else {
                                <p class="lead text-center mb-4">Acceda a su agenda y gestione pacientes.</p>
                            }

                            <!-- Quick Stats Row -->
                            <div class="row g-3 mb-4 text-center">
                                <div class="col-md-4">
                                    <div class="stat-card p-3 border border-info-subtle rounded bg-info-subtle modern-card-hover">
                                        <h5 class="stat-value mb-1 fs-2 fw-bold text-info text-shadow-custom" id="doctorCitasHoyStat">0</h5>
                                        <p class="stat-label mb-0 text-muted small text-uppercase">Citas Hoy</p>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat-card p-3 border border-info-subtle rounded bg-info-subtle modern-card-hover">
                                        <h5 class="stat-value mb-1 fs-2 fw-bold text-info text-shadow-custom" id="doctorCitasConfirmadasStat">0</h5>
                                        <p class="stat-label mb-0 text-muted small text-uppercase">Citas Confirmadas</p>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat-card p-3 border border-info-subtle rounded bg-info-subtle modern-card-hover">
                                        <h5 class="stat-value mb-1 fs-2 fw-bold text-info text-shadow-custom" id="doctorSatisfaccionStat">0%</h5>
                                        <p class="stat-label mb-0 text-muted small text-uppercase">Satisfacción</p>
                                    </div>
                                </div>
                            </div>
                            <!-- End Quick Stats Row -->

                            <hr class="my-4">

                            <h4 class="mb-3 text-center fw-normal text-info-emphasis">Acciones Principales</h4>
                            <div class="row justify-content-center text-center g-4 mb-4">
                                <div class="col-md-6 col-lg-4">
                                    <div class="card h-100 shadow-lg border-info action-card-hover feature-card-hover">
                                        <div class="card-body d-flex flex-column align-items-center p-4">
                                            <div class="feature-icon-wrapper mb-3">
                                                <i class="bi bi-calendar-week-fill fs-1 text-info feature-icon-main rotating-icon"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                    <span class="sparkle sparkle-4"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Mi Agenda</h5>
                                            <p class="card-text flex-grow-1 small text-muted">Vea sus citas, detalles y añada prescripciones.</p>
                                            <a asp-page="/Doctor/Agenda" class="btn btn-info mt-auto w-100 fw-semibold"><i class="bi bi-arrow-right-circle me-1"></i> Ver Agenda</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 col-lg-4">
                                    <div class="card h-100 shadow-lg border-info action-card-hover feature-card-hover">
                                        <div class="card-body d-flex flex-column align-items-center p-4">
                                            <div class="feature-icon-wrapper mb-3">
                                                <i class="bi bi-people-fill fs-1 text-info feature-icon-main rotating-icon"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                    <span class="sparkle sparkle-4"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Mis Pacientes</h5>
                                            <p class="card-text flex-grow-1 small text-muted">Consulte pacientes atendidos y vea su historial.</p>
                                            <a asp-page="/Doctor/Patients" class="btn btn-info mt-auto w-100 fw-semibold"><i class="bi bi-list-check me-1"></i> Ver Pacientes</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 col-lg-4">
                                    <div class="card h-100 shadow-lg border-info action-card-hover feature-card-hover">
                                        <div class="card-body d-flex flex-column align-items-center p-4">
                                            <div class="feature-icon-wrapper mb-3">
                                                <i class="bi bi-person-fill-gear fs-1 text-info feature-icon-main rotating-icon"></i>
                                                <div class="feature-sparkles">
                                                    <span class="sparkle sparkle-1"></span>
                                                    <span class="sparkle sparkle-2"></span>
                                                    <span class="sparkle sparkle-3"></span>
                                                    <span class="sparkle sparkle-4"></span>
                                                </div>
                                            </div>
                                            <h5 class="card-title">Mi Perfil</h5>
                                            <p class="card-text flex-grow-1 small text-muted">Actualice su información profesional.</p>
                                            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-info mt-auto w-100 fw-semibold"><i class="bi bi-pencil-square me-1"></i> Actualizar Perfil</a>
                                        </div>
                                    </div>
                                </div>
                                @* Add more Doctor specific cards here if needed *@
                            </div>

                            <hr class="my-4">

                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <h5 class="mb-3 text-info-emphasis"><i class="bi bi-tools me-2"></i>Herramientas Rápidas</h5>
                                    <div class="list-group shadow-sm quick-links-widget">
                                        <div class="list-group-item p-0">
                                            <form id="doctorPatientSearchForm" class="d-flex p-2">
                                                <input type="text" id="doctorPatientSearchInput" class="form-control form-control-sm me-2" placeholder="Buscar Paciente...">
                                                <button type="submit" class="btn btn-sm btn-outline-info"><i class="bi bi-search"></i></button>
                                            </form>
                                        </div>
                                        <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                            Configurar Notificaciones
                                            <i class="bi bi-bell-slash text-muted"></i>
                                        </a>
                                        <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                            Base de Conocimiento Médico
                                            <i class="bi bi-book text-muted"></i>
                                        </a>
                                        <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                            Ver Estadísticas Completas
                                            <i class="bi bi-graph-up text-muted"></i>
                                        </a>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <h5 class="mb-3 text-info-emphasis"><i class="bi bi-newspaper me-2"></i>Novedades y Anuncios</h5>
                                    <div class="card shadow-sm announcements-widget">
                                        <div class="card-body">
                                            <p class="card-text text-muted small">
                                                <strong>15 Julio, 2024:</strong> Nueva actualización del sistema de agendamiento. Revise el manual actualizado.
                                            </p>
                                            <hr class="my-2">
                                            <p class="card-text text-muted small">
                                                <strong>10 Julio, 2024:</strong> Próxima jornada de capacitación sobre CIE-11 el 1 de Agosto. Inscríbase!
                                            </p>
                                            <a href="#" class="btn btn-sm btn-outline-info mt-2 float-end">Ver todos</a>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                        
                        <!-- Trust Indicators for Doctor -->
                        <div class="card-footer bg-light text-center py-4">
                            <div class="row align-items-center text-muted">
                                <div class="col-md-3 mb-3 mb-md-0">
                                    <i class="bi bi-award-fill fs-4 text-info mb-2 d-block"></i>
                                    <div class="small">Certificado ISO 9001</div>
                                </div>
                                <div class="col-md-3 mb-3 mb-md-0">
                                    <i class="bi bi-shield-check fs-4 text-info mb-2 d-block"></i>
                                    <div class="small">Ministerio de Salud</div>
                                </div>
                                <div class="col-md-3 mb-3 mb-md-0">
                                    <i class="bi bi-star-fill fs-4 text-info mb-2 d-block"></i>
                                    <div class="small">Premio Innovación 2024</div>
                                </div>
                                <div class="col-md-3 mb-3 mb-md-0">
                                    <i class="bi bi-globe fs-4 text-info mb-2 d-block"></i>
                                    <div class="small">Red Internacional</div>
                                </div>
                            </div>
                            <p class="mb-0 text-muted small mt-3">Herramientas para Profesionales de la Salud - Reconocido por Instituciones Líderes</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (User.IsInRole("Paciente"))
        {
            <div id="patientPanelDashboard" class="row justify-content-center">
                <div class="col-lg-11 col-xl-10">
                    <!-- Header simplificado -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #1a5e3a 0%, #2d7a4a 100%); color: white;">
                                <div class="card-body text-center py-4">
                                    <h2 class="mb-2" style="color: white;">
                                        <i class="bi bi-person-heart me-2" style="color: white;"></i>
                                        @if (!string.IsNullOrEmpty(userFirstName))
                                        {
