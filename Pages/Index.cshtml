@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Patient Dashboard - Load with delay
            setTimeout(() => {
                if (document.getElementById('patientNextAppointmentDisplay')) {
                    loadPatientRealData();
                }
            }, 1000);

            // Doctor Dashboard - Load with delay
            setTimeout(() => {
            const citasHoyStatElement = document.getElementById('doctorCitasHoyStat');
            if (citasHoyStatElement) {
                loadDoctorDashboardData();
            }
            }, 1000);

            // Doctor Dashboard: Patient Search Form
            const doctorPatientSearchForm = document.getElementById('doctorPatientSearchForm');
            if (doctorPatientSearchForm) {
                doctorPatientSearchForm.addEventListener('submit', function (event) {
                    event.preventDefault();
                    const searchInput = document.getElementById('doctorPatientSearchInput');
                    if (searchInput && searchInput.value.trim() !== '') {
                        searchPatients(searchInput.value.trim());
                        searchInput.value = '';
                    } else {
                        showNotification('Por favor ingrese un término de búsqueda.', 'warning');
                    }
                });
            }
            
            // Scroll to Top Button
            const scrollToTopBtn = document.getElementById('scrollToTopBtn');
            if (scrollToTopBtn) {
                let scrollToTopVisible = false;
                window.addEventListener('scroll', function() {
                    const shouldShow = window.pageYOffset > 300;
                    if (shouldShow !== scrollToTopVisible) {
                        scrollToTopVisible = shouldShow;
                        scrollToTopBtn.classList.toggle('show', shouldShow);
                    }
                }, { passive: true });
                
                scrollToTopBtn.addEventListener('click', function() {
                    document.body.classList.add('scrolling');
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                    setTimeout(() => {
                        document.body.classList.remove('scrolling');
                    }, 1000);
                });
            }
        });

        // Función para cargar datos reales del paciente
        async function loadPatientRealData() {
            try {
                // Cargar próxima cita
                const nextAppointmentResponse = await fetch('/api/patient/next-appointment');
                if (nextAppointmentResponse.ok) {
                    const nextAppointment = await nextAppointmentResponse.json();
                    const nextAppointmentElement = document.getElementById('patientNextAppointmentDisplay');
                    if (nextAppointment && nextAppointment.appointmentDate) {
                        const date = new Date(nextAppointment.appointmentDate);
                        nextAppointmentElement.innerHTML = `
                            <i class="bi bi-calendar-week text-primary me-2"></i>
                            <span>${date.toLocaleDateString('es-CO', { 
                                month: 'short', 
                                day: 'numeric',
                                hour: '2-digit',
                                minute: '2-digit'
                            })} - ${nextAppointment.doctorName}</span>
                        `;
                    } else {
                        nextAppointmentElement.innerHTML = `
                            <i class="bi bi-calendar-x text-muted me-2"></i>
                            <span>No hay citas programadas</span>
                        `;
                    }
                }

                // Cargar recetas activas
                const prescriptionsResponse = await fetch('/api/patient/active-prescriptions-count');
                if (prescriptionsResponse.ok) {
                    const prescriptions = await prescriptionsResponse.json();
                    document.getElementById('patientPrescriptionsCount').innerHTML = `
                        <i class="bi bi-prescription2 text-success me-2"></i>
                        <span>${prescriptions.count || 0}</span>
                    `;
                }

                // Cargar estado de salud
                const healthResponse = await fetch('/api/patient/health-status');
                if (healthResponse.ok) {
                    const healthData = await healthResponse.json();
                    
                    // Actualizar última consulta
                    const lastConsultationElement = document.getElementById('lastConsultationDate');
                    if (healthData.lastConsultation) {
                        const date = new Date(healthData.lastConsultation);
                        lastConsultationElement.textContent = date.toLocaleDateString('es-CO');
                    } else {
                        lastConsultationElement.textContent = 'Sin consultas previas';
                    }

                    // Actualizar próximo chequeo
                    const nextCheckupElement = document.getElementById('nextCheckupDate');
                    if (healthData.nextCheckup) {
                        const date = new Date(healthData.nextCheckup);
                        nextCheckupElement.textContent = date.toLocaleDateString('es-CO');
                        nextCheckupElement.classList.add('text-warning', 'fw-bold');
                    } else {
                        nextCheckupElement.textContent = 'No programado';
                    }

                    // Actualizar recordatorios
                    document.getElementById('activeRemindersCount').textContent = healthData.reminders || 0;
                }

                // Cargar mensajes
                const messagesResponse = await fetch('/api/patient/recent-messages');
                if (messagesResponse.ok) {
                    const messages = await messagesResponse.json();
                    const messagesContainer = document.getElementById('messagesContainer');
                    
                    if (messages.length > 0) {
                        messagesContainer.innerHTML = messages.map(msg => `
                            <p class="card-text text-muted small">
                                <strong><i class="bi bi-${msg.type === 'medical' ? 'stethoscope' : 'info-circle'} text-info me-1"></i>${msg.sender}:</strong> 
                                ${msg.content}
                            </p>
                        `).join('<hr class="my-1">');
                    }
                    
                    document.getElementById('unreadMessagesCount').textContent = messages.filter(m => !m.read).length;
                }

            } catch (error) {
                console.error('Error cargando datos del paciente:', error);
                loadPatientFallbackData();
            }
        }

        // Función fallback con datos por defecto
        function loadPatientFallbackData() {
            document.getElementById('patientNextAppointmentDisplay').innerHTML = `
                <i class="bi bi-calendar-plus text-primary me-2"></i>
                <span>Agende su próxima cita</span>
            `;
            document.getElementById('lastConsultationDate').textContent = 'No disponible';
            document.getElementById('nextCheckupDate').textContent = 'No programado';
        }

        // Función para cargar datos reales del doctor
        async function loadDoctorDashboardData() {
            try {
                const response = await fetch('/api/doctor/dashboard-stats');
                if (response.ok) {
                    const stats = await response.json();
                    document.getElementById('doctorCitasHoyStat').textContent = stats.todayAppointments || 0;
                    document.getElementById('doctorCitasConfirmadasStat').textContent = stats.confirmedAppointments || 0;
                    document.getElementById('doctorSatisfaccionStat').textContent = (stats.satisfactionPercentage || 0) + '%';
                }
            } catch (error) {
                console.error('Error cargando datos del doctor:', error);
                document.getElementById('doctorCitasHoyStat').textContent = '0';
                document.getElementById('doctorCitasConfirmadasStat').textContent = '0';
                document.getElementById('doctorSatisfaccionStat').textContent = '0%';
            }
        }

        // Función para buscar pacientes
        async function searchPatients(searchTerm) {
            try {
                const response = await fetch(`/api/doctor/search-patients?term=${encodeURIComponent(searchTerm)}`);
                if (response.ok) {
                    const patients = await response.json();
                    displaySearchResults(patients);
                } else {
                    showNotification('Error al buscar pacientes', 'error');
                }
            } catch (error) {
                console.error('Error en búsqueda de pacientes:', error);
                showNotification('Error de conexión al buscar pacientes', 'error');
            }
        }

        // Función para mostrar resultados de búsqueda
        function displaySearchResults(patients) {
            if (patients.length === 0) {
                showNotification('No se encontraron pacientes con ese término', 'info');
                return;
            }

            let resultsHtml = '<div class="search-results-dropdown">';
            patients.forEach(patient => {
                resultsHtml += `
                    <div class="search-result-item" onclick="selectPatient('${patient.id}')">
                        <strong>${patient.name}</strong><br>
                        <small>${patient.email} - ${patient.phone}</small>
                    </div>
                `;
            });
            resultsHtml += '</div>';
            
            showNotification(`Encontrados ${patients.length} paciente(s)`, 'success');
        }

        // Función para seleccionar un paciente
        function selectPatient(patientId) {
            window.location.href = `/Doctor/PatientDetail/${patientId}`;
        }

        // Función para mostrar notificaciones
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.className = `alert alert-${type === 'error' ? 'danger' : type} alert-dismissible fade show position-fixed`;
            notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
            notification.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }
    </script>
}

