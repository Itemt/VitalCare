@page
@model CitasEPS.Pages.ContactModel
@{
    ViewData["Title"] = "Contacto - VitalCare";
}

<style>
    /* === FIX DEFINITIVO PARA TARJETAS Y NAVBAR === */

    /* 1. Arreglo del Navbar: Desactivar solo transformaciones en los enlaces */
    .navbar-nav .nav-link {
        transform: none !important;
        animation: none !important;
        transition: background-color 0.2s ease, color 0.2s ease !important;
    }

    /* 2. Centrado de Tarjetas de Contacto Superiores */
    .contact-cards-container {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 2rem;
        padding: 1rem 0;
    }

    .contact-card {
        width: 100%;
        max-width: 350px;
        flex-grow: 1;
        flex-basis: 300px;
        border-radius: 1rem !important;
        transition: transform 0.3s ease, box-shadow 0.3s ease !important;
    }
    
    .contact-card:hover {
        transform: translateY(-8px) !important;
        box-shadow: 0 15px 30px rgba(0,0,0,0.15) !important;
    }

    /* 3. Tarjetas de Información de Oficina */
    .info-card {
        background-color: var(--bs-light);
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        padding: 1rem;
        height: 100%;
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .info-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
    }
    .info-card .info-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        display: block;
    }
    .info-card .info-title {
        font-weight: 700;
        color: var(--bs-dark);
        margin-bottom: 0.5rem;
    }


    /* === HERO MODERNO PARA CONTACT === */
    
    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }
    
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .hero-modern {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 25%, #334155 50%, #1e293b 75%, #0f172a 100%);
        position: relative;
        overflow: hidden;
        min-height: 80vh;
        display: flex;
        align-items: center;
        border-radius: 2rem;
        margin: 1rem;
    }
    
    .hero-content {
        position: relative;
        z-index: 2;
        background: rgba(15, 23, 42, 0.95);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 3rem;
        padding: 4rem;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        margin: 2rem;
    }
    
    .hero-title-gradient {
        background: linear-gradient(135deg, #3b82f6 0%, #10b981 50%, #8b5cf6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-size: 4.5rem;
        font-weight: 900;
        line-height: 1.3;
        padding: 0.2rem 0;
        margin: 0.5rem 0;
    }
    
    .particles {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        pointer-events: none;
        border-radius: inherit;
    }
    
    .particle {
        position: absolute;
        background: rgba(59, 130, 246, 0.2);
        border-radius: 50%;
        animation: float 6s ease-in-out infinite;
    }
    
    .particle:nth-child(1) { left: 15%; top: 20%; width: 8px; height: 8px; animation-delay: 0s; }
    .particle:nth-child(2) { left: 75%; top: 60%; width: 6px; height: 6px; animation-delay: 2s; }
    .particle:nth-child(3) { left: 45%; top: 80%; width: 4px; height: 4px; animation-delay: 4s; }
    
    .animate-fade-up { animation: fadeInUp 0.8s ease-out; }
    
    [data-bs-theme="dark"] .hero-modern {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 25%, #334155 50%, #1e293b 75%, #0f172a 100%);
    }
    
    [data-bs-theme="dark"] .hero-content {
        background: rgba(13, 13, 13, 0.9);
        border-color: rgba(255,255,255,0.2);
    }

</style>

<!-- Hero Section Moderno -->
<section class="hero-modern mb-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="hero-content animate-fade-up text-center">
                    <h1 class="hero-title-gradient mb-4">
                        Contáctanos Hoy
                    </h1>
                    <p class="lead text-white mb-5 fs-3">
                        Estamos aquí para resolver tus dudas y acompañarte en cada paso 
                        de tu experiencia de salud. Tu bienestar es nuestra prioridad.
                    </p>
                    <div class="row g-3 mt-4">
                        <div class="col-md-4">
                            <div class="badge text-white p-3 fs-6 fw-bold" style="background: linear-gradient(135deg, #22c55e, #16a34a); box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);">
                                <i class="bi bi-telephone-fill me-2"></i>Línea Directa
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="badge text-white p-3 fs-6 fw-bold" style="background: linear-gradient(135deg, #3b82f6, #2563eb); box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);">
                                <i class="bi bi-chat-dots-fill me-2"></i>Chat en Línea
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="badge text-white p-3 fs-6 fw-bold" style="background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);">
                                <i class="bi bi-geo-alt-fill me-2"></i>Ubicación Central
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact Methods -->
<div class="container mb-5">
    <div class="row text-center mb-5">
        <div class="col-lg-8 mx-auto">
            <h2 class="display-5 fw-bold mb-3" style="color: #003366;">Múltiples Formas de Contactarnos</h2>
            <p class="lead text-muted">Elige el canal que prefieras para comunicarte con nuestro equipo</p>
        </div>
    </div>
    
    <div class="contact-cards-container">
        <div class="card shadow-lg border-0 contact-card text-center">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-telephone-fill" style="font-size: 4rem; color: #003366;"></i>
                </div>
                <h5 class="card-title fw-bold" style="color: #003366;">Llámanos</h5>
                <p class="card-text text-muted mb-3">Atención telefónica personalizada las 24 horas del día, los 7 días de la semana.</p>
                <h4 class="fw-bold text-success mb-3">+57 320 346 5135</h4>
                <div class="contact-details">
                    <small class="d-block text-success mb-1"><i class="bi bi-clock-fill me-1"></i>Disponible 24/7</small>
                    <small class="d-block text-info"><i class="bi bi-chat-square-text-fill me-1"></i>Español e Inglés</small>
                </div>
                <button class="btn mt-3" style="background: linear-gradient(135deg, #003366, #002244); color: white;" onclick="window.location.href='tel:+573203465135'">
                    <i class="bi bi-telephone-fill me-2"></i>Llamar Ahora
                </button>
            </div>
        </div>
        
        <div class="card shadow-lg border-0 contact-card text-center">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-envelope-fill" style="font-size: 4rem; color: #22816b;"></i>
                </div>
                <h5 class="card-title fw-bold text-success">Escríbenos</h5>
                <p class="card-text text-muted mb-3">Envíanos un correo electrónico y te responderemos en menos de 2 horas.</p>
                <h4 class="fw-bold mb-3" style="color: #003366;">cramos5@udi.edu.co</h4>
                <div class="contact-details">
                    <small class="d-block text-success mb-1"><i class="bi bi-clock-fill me-1"></i>Respuesta en 2h</small>
                    <small class="d-block text-info"><i class="bi bi-shield-check-fill me-1"></i>Cifrado SSL</small>
                </div>
                <button class="btn btn-success mt-3" onclick="window.location.href='mailto:cramos5@udi.edu.co'">
                    <i class="bi bi-envelope-fill me-2"></i>Enviar Email
                </button>
            </div>
        </div>
        
        <div class="card shadow-lg border-0 contact-card text-center">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-chat-dots-fill" style="font-size: 4rem; color: #17a2b8;"></i>
                </div>
                <h5 class="card-title fw-bold text-info">Chat en Vivo</h5>
                <p class="card-text text-muted mb-3">Chatea con nuestros especialistas en tiempo real para resolver tus dudas.</p>
                <h4 class="fw-bold text-warning mb-3">Respuesta Inmediata</h4>
                <div class="contact-details">
                    <small class="d-block text-success mb-1"><i class="bi bi-lightning-charge-fill me-1"></i>Tiempo real</small>
                    <small class="d-block text-info"><i class="bi bi-people-fill me-1"></i>Especialistas online</small>
                </div>
                <button class="btn btn-info mt-3" data-bs-toggle="modal" data-bs-target="#chatModal">
                    <i class="bi bi-chat-dots-fill me-2"></i>Iniciar Chat
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Contact Form -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="alert @(Model.StatusMessage.StartsWith("Error") ? "alert-danger" : "alert-success") alert-dismissible fade show mb-4" role="alert">
                        <i class="bi @(Model.StatusMessage.StartsWith("Error") ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                        @Model.StatusMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                
                <div class="card shadow-lg border-0">
                    <div class="card-header text-white text-center py-4" style="background: linear-gradient(135deg, #003366, #002244);">
                        <h3 class="fw-bold mb-0">
                            <i class="bi bi-envelope-paper-fill me-2"></i>
                            Formulario de Contacto
                        </h3>
                        <p class="mb-0 text-white-50">Completa el formulario y nos comunicaremos contigo</p>
                    </div>
                    <div class="card-body p-5">
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                            
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Input.FirstName" class="form-label fw-semibold">
                                        <i class="bi bi-person-fill me-1" style="color: #003366;"></i>Nombre
                                    </label>
                                    <input asp-for="Input.FirstName" class="form-control form-control-lg" placeholder="Tu nombre">
                                    <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Input.LastName" class="form-label fw-semibold">
                                        <i class="bi bi-person-fill me-1" style="color: #003366;"></i>Apellido
                                    </label>
                                    <input asp-for="Input.LastName" class="form-control form-control-lg" placeholder="Tu apellido">
                                    <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Input.Email" class="form-label fw-semibold">
                                        <i class="bi bi-envelope-fill me-1" style="color: #003366;"></i>Correo Electrónico
                                    </label>
                                    <input asp-for="Input.Email" type="email" class="form-control form-control-lg" placeholder="tu@email.com">
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Input.Phone" class="form-label fw-semibold">
                                        <i class="bi bi-telephone-fill me-1" style="color: #003366;"></i>Teléfono
                                    </label>
                                    <input asp-for="Input.Phone" type="tel" class="form-control form-control-lg" placeholder="Tu número de teléfono">
                                    <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="Input.Subject" class="form-label fw-semibold">
                                        <i class="bi bi-tag-fill me-1" style="color: #003366;"></i>Asunto
                                    </label>
                                    <select asp-for="Input.Subject" class="form-select form-select-lg">
                                        <option value="">Selecciona un asunto</option>
                                        <option value="Consulta General">Consulta General</option>
                                        <option value="Soporte Técnico">Soporte Técnico</option>
                                        <option value="Agendar Cita">Agendar Cita</option>
                                        <option value="Emergencia Médica">Emergencia Médica</option>
                                        <option value="Facturación">Facturación</option>
                                        <option value="Otro">Otro</option>
                                    </select>
                                    <span asp-validation-for="Input.Subject" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="Input.Message" class="form-label fw-semibold">
                                        <i class="bi bi-chat-square-text-fill me-1" style="color: #003366;"></i>Mensaje
                                    </label>
                                    <textarea asp-for="Input.Message" class="form-control" rows="5" placeholder="Describe tu consulta o solicitud en detalle..."></textarea>
                                    <span asp-validation-for="Input.Message" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <div class="form-check">
                                        <input asp-for="Input.AcceptPrivacy" class="form-check-input" type="checkbox" id="privacy">
                                        <label class="form-check-label" for="privacy">
                                            Acepto la <a href="#" style="color: #003366;">política de privacidad</a> y el tratamiento de mis datos personales
                                        </label>
                                        <div>
                                            <span asp-validation-for="Input.AcceptPrivacy" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 text-center">
                                    <button type="submit" class="btn btn-lg px-5" style="background: linear-gradient(135deg, #003366, #002244); color: white;">
                                        <i class="bi bi-send-fill me-2"></i>Enviar Mensaje
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

