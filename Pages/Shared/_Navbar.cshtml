@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using CitasEPS.Models

@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@inject IAuthorizationService AuthorizationService

@{
    var isDoctorLoggedIn = (bool)(ViewData["IsDoctorLoggedIn"] ?? false);
    var isPatientLoggedIn = (bool)(ViewData["IsPatientLoggedIn"] ?? false);
    var isAdminLoggedIn = (bool)(ViewData["IsAdminLoggedIn"] ?? false);
}

<header class="sticky-top">
    <nav class="navbar navbar-expand-xl bg-white shadow-sm">
        <div class="container-fluid px-3">
            @* LOGO *@
            <a class="navbar-brand d-flex align-items-center" asp-area="" asp-page="/Index">
                <i class="bi bi-heart-pulse-fill me-2 brand-icon"></i> 
                <span class="brand-text">Vital<span class="text-primary">Care</span></span>
            </a>
            
            @* CONTROLES MÓVILES *@
            <div class="d-xl-none d-flex align-items-center gap-2">
                @if (!SignInManager.IsSignedIn(User))
                {
                    <button class="btn btn-outline-secondary btn-sm" type="button" id="themeToggleMobile">
                        <i class="bi bi-sun-fill theme-icon-sun"></i>
                        <i class="bi bi-moon-stars-fill theme-icon-moon d-none"></i>
                    </button>
                }
                <button class="navbar-toggler border-0 custom-hamburger" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <div class="hamburger-lines">
                        <span class="line line1"></span>
                        <span class="line line2"></span>
                        <span class="line line3"></span>
                    </div>
                </button>
            </div>
            
            @* CONTENIDO PRINCIPAL *@
            <div class="collapse navbar-collapse" id="navbarContent">
                @* NAVEGACIÓN DESKTOP *@
                <ul class="navbar-nav me-auto mb-2 mb-xl-0 d-none d-xl-flex">
                    @* INICIO *@
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" asp-area="" asp-page="/Index">
                            <i class="bi bi-house-door-fill me-1"></i> Inicio
                        </a>
                    </li>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        @if (isAdminLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Admin/ManageUsers">
                                    <i class="bi bi-person-gear me-1"></i> Administración
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Admin/ManageAppointments">
                                    <i class="bi bi-calendar-check-fill me-1"></i> Gestionar Citas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Admin/ManageDoctors">
                                    <i class="bi bi-file-medical-fill me-1"></i> Gestionar Médicos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Admin/ManagePatients">
                                    <i class="bi bi-person-lines-fill me-1"></i> Gestionar Pacientes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Admin/Medications/Index">
                                    <i class="bi bi-capsule-pill me-1"></i> Medicamentos
                                </a>
                            </li>
                        } 
                        else if (isDoctorLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Doctor/Agenda">
                                    <i class="bi bi-calendar-week-fill me-1"></i> Mi Agenda
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Doctor/Patients">
                                    <i class="bi bi-person-badge-fill me-1"></i> Mis Pacientes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Appointments/Index">
                                    <i class="bi bi-calendar-event me-1"></i> Ver Citas
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link nav-link-custom dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots me-1"></i> Más
                                </a>
                                <ul class="dropdown-menu dropdown-menu-custom">
                                    <li><a class="dropdown-item dropdown-item-custom" asp-area="" asp-page="/Servicios">
                                        <i class="bi bi-gear-fill me-2"></i> Servicios
                                    </a></li>
                                    <li><a class="dropdown-item dropdown-item-custom" asp-area="" asp-page="/About">
                                        <i class="bi bi-building me-2"></i> Sobre Nosotros
                                    </a></li>
                                    <li><a class="dropdown-item dropdown-item-custom" asp-area="" asp-page="/Team">
                                        <i class="bi bi-people-fill me-2"></i> Equipo
                                    </a></li>
                                    <li><a class="dropdown-item dropdown-item-custom" asp-area="" asp-page="/Contact">
                                        <i class="bi bi-envelope-fill me-2"></i> Contacto
                                    </a></li>
                                    <li><a class="dropdown-item dropdown-item-custom" asp-area="" asp-page="/Support">
                                        <i class="bi bi-headset me-2"></i> Soporte Técnico
                                    </a></li>
                                    <li><a class="dropdown-item dropdown-item-custom" asp-area="" asp-page="/FAQ">
                                        <i class="bi bi-question-circle-fill me-2"></i> FAQ
                                    </a></li>
                                </ul>
                            </li>
                        } 
                        else if (isPatientLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Appointments/Create">
                                    <i class="bi bi-calendar-plus-fill me-1"></i> Agendar Cita
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Appointments/Index">
                                    <i class="bi bi-calendar-event-fill me-1"></i> Mis Citas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Appointments/MyPrescriptions">
                                    <i class="bi bi-journal-medical me-1"></i> Mis Recetas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Patient/HealthStatus">
                                    <i class="bi bi-heart-pulse-fill me-1"></i> Mi Salud
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        @* USUARIOS NO LOGUEADOS *@
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-page="/Servicios">
                                <i class="bi bi-gear-fill me-1"></i> Servicios
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-page="/About">
                                <i class="bi bi-building me-1"></i> Sobre Nosotros
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-page="/Team">
                                <i class="bi bi-people-fill me-1"></i> Equipo
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-page="/Contact">
                                <i class="bi bi-envelope-fill me-1"></i> Contacto
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-page="/Support">
                                <i class="bi bi-headset me-1"></i> Soporte Técnico
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-page="/FAQ">
                                <i class="bi bi-question-circle-fill me-1"></i> FAQ
                            </a>
                        </li>
                    }
                </ul>

                @* NAVEGACIÓN MÓVIL EN COLUMNAS *@
                <div class="d-xl-none mobile-menu-container">
                    <div class="container-fluid">
                        <div class="row g-3">
                            @* COLUMNA PRINCIPAL *@
                            <div class="col-12">
                                <div class="mobile-menu-section">
                                    <h6 class="mobile-menu-title">Navegación Principal</h6>
                                                                        <div class="row">
                                        <div class="col-md-6 col-12">
                                            <a class="mobile-menu-item" asp-area="" asp-page="/Index">
                                                <i class="bi bi-house-door-fill me-2"></i> 
                                                <span>Inicio</span>
                                            </a>
                                        </div>
                    @if (SignInManager.IsSignedIn(User))
                    {
                                            @if (isAdminLoggedIn)
                                            {
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Admin/ManageUsers">
                                                        <i class="bi bi-person-gear me-2"></i> 
                                                        <span>Administración</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Admin/ManageAppointments">
                                                        <i class="bi bi-calendar-check-fill me-2"></i> 
                                                        <span>Gestionar Citas</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Admin/ManageDoctors">
                                                        <i class="bi bi-file-medical-fill me-2"></i> 
                                                        <span>Gestionar Médicos</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Admin/ManagePatients">
                                                        <i class="bi bi-person-lines-fill me-2"></i> 
                                                        <span>Gestionar Pacientes</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Admin/Medications/Index">
                                                        <i class="bi bi-capsule-pill me-2"></i> 
                                                        <span>Medicamentos</span>
                                                    </a>
                                                </div>
                                            } 
                                            else if (isDoctorLoggedIn)
                                            {
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Doctor/Agenda">
                                                        <i class="bi bi-calendar-week-fill me-2"></i> 
                                                        <span>Mi Agenda</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Doctor/Patients">
                                                        <i class="bi bi-person-badge-fill me-2"></i> 
                                                        <span>Mis Pacientes</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Appointments/Index">
                                                        <i class="bi bi-calendar-event me-2"></i> 
                                                        <span>Ver Citas</span>
                                                    </a>
                                                </div>
                                            } 
                                            else if (isPatientLoggedIn)
                                            {
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Appointments/Create">
                                                        <i class="bi bi-calendar-plus-fill me-2"></i> 
                                                        <span>Agendar Cita</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Appointments/Index">
                                                        <i class="bi bi-calendar-event-fill me-2"></i> 
                                                        <span>Mis Citas</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Appointments/MyPrescriptions">
                                                        <i class="bi bi-journal-medical me-2"></i> 
                                                        <span>Mis Recetas</span>
                                                    </a>
                                                </div>
                                                <div class="col-md-6 col-12">
                                                    <a class="mobile-menu-item" asp-page="/Patient/HealthStatus">
                                                        <i class="bi bi-heart-pulse-fill me-2"></i> 
                                                        <span>Mi Salud</span>
                                                    </a>
                                                </div>
                                            }
                    }
                    else
                    {
                                            @* USUARIOS NO LOGUEADOS *@
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/Servicios">
                                                    <i class="bi bi-gear-fill me-2"></i> 
                                                    <span>Servicios</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/About">
                                                    <i class="bi bi-building me-2"></i> 
                                                    <span>Sobre Nosotros</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/Team">
                                                    <i class="bi bi-people-fill me-2"></i> 
                                                    <span>Equipo</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/Contact">
                                                    <i class="bi bi-envelope-fill me-2"></i> 
                                                    <span>Contacto</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/Support">
                                                    <i class="bi bi-headset me-2"></i> 
                                                    <span>Soporte Técnico</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/FAQ">
                                                    <i class="bi bi-question-circle-fill me-2"></i> 
                                                    <span>FAQ</span>
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* SECCIÓN ADICIONAL PARA DOCTORES *@
                            @if (SignInManager.IsSignedIn(User) && isDoctorLoggedIn)
                            {
                                <div class="col-12">
                                    <div class="mobile-menu-section">
                                        <h6 class="mobile-menu-title">Información y Soporte</h6>
                                        <div class="row">
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/Servicios">
                                                    <i class="bi bi-gear-fill me-2"></i> 
                                                    <span>Servicios</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/About">
                                                    <i class="bi bi-building me-2"></i> 
                                                    <span>Sobre Nosotros</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/Team">
                                                    <i class="bi bi-people-fill me-2"></i> 
                                                    <span>Equipo</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/Contact">
                                                    <i class="bi bi-envelope-fill me-2"></i> 
                                                    <span>Contacto</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/Support">
                                                    <i class="bi bi-headset me-2"></i> 
                                                    <span>Soporte Técnico</span>
                                                </a>
                                            </div>
                                            <div class="col-md-6 col-12">
                                                <a class="mobile-menu-item" asp-area="" asp-page="/FAQ">
                                                    <i class="bi bi-question-circle-fill me-2"></i> 
                                                    <span>FAQ</span>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* LADO DERECHO *@
                <div class="d-flex align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        var currentUser = await UserManager.GetUserAsync(User);
                        var displayName = currentUser?.FirstName + " " + currentUser?.LastName;
                        if (string.IsNullOrWhiteSpace(displayName?.Trim()))
                        {
                            displayName = UserManager.GetUserName(User);
                        }

                        @* BOTÓN DE TEMA *@
                        <button class="btn btn-outline-secondary btn-sm me-3 d-none d-xl-flex" type="button" id="themeToggle">
                            <i class="bi bi-sun-fill theme-icon-sun"></i>
                            <i class="bi bi-moon-stars-fill theme-icon-moon d-none"></i>
                        </button>

                        @* NOTIFICACIONES *@
                        <div class="dropdown me-3">
                            <button class="btn btn-outline-primary btn-sm position-relative" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-bell-fill"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="notificationBadge">1</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-custom" style="width: 300px;">
                                <li><h6 class="dropdown-header">Notificaciones</h6></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><div class="text-center p-3 text-muted">Sin notificaciones</div></li>
                            </ul>
                        </div>

                        @* USUARIO *@
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle user-dropdown" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> 
                                <span class="d-none d-md-inline">@displayName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-custom">
                                <li><a class="dropdown-item dropdown-item-custom" asp-area="Identity" asp-page="/Account/Manage/Index">
                                    <i class="bi bi-gear me-2"></i> Mi Cuenta
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                                        <button type="submit" class="dropdown-item dropdown-item-custom">
                                            <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        @* BOTÓN DE TEMA PARA NO LOGUEADOS - DESKTOP *@
                        <button class="btn btn-outline-secondary btn-sm me-3 d-none d-xl-flex" type="button" id="themeToggle">
                            <i class="bi bi-sun-fill theme-icon-sun"></i>
                            <i class="bi bi-moon-stars-fill theme-icon-moon d-none"></i>
                        </button>

                        @* BOTONES DE AUTENTICACIÓN - DESKTOP *@
                        <div class="d-none d-xl-flex gap-2">
                            <a class="btn btn-auth btn-register" asp-area="Identity" asp-page="/Account/Register">
                                <i class="bi bi-person-plus me-1"></i> 
                                <span>Registrarse</span>
                                <div class="btn-sweep"></div>
                            </a>
                            <a class="btn btn-auth btn-login" asp-area="Identity" asp-page="/Account/Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> 
                                <span>Iniciar Sesión</span>
                                <div class="btn-sweep"></div>
                            </a>
                        </div>
                        
                        @* BOTONES DE AUTENTICACIÓN - MOBILE *@
                        <div class="d-xl-none w-100 mt-3">
                            <div class="d-flex gap-2 justify-content-center">
                                <a class="btn btn-auth btn-register" asp-area="Identity" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus me-1"></i>
                                    <span>Registrarse</span>
                                    <div class="btn-sweep"></div>
                                </a>
                                <a class="btn btn-auth btn-login" asp-area="Identity" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>
                                    <span>Iniciar Sesión</span>
                                    <div class="btn-sweep"></div>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </nav>
</header>

<style>
/* === NAVBAR BASE === */
.navbar {
    background: rgba(255, 255, 255, 0.95) !important;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    padding: 0.75rem 0;
    min-height: 70px;
}

/* === BRAND === */
.navbar-brand {
    font-size: 1.5rem !important;
    font-weight: 700;
    color: #1a202c !important;
    text-decoration: none;
    line-height: 1.2;
    height: auto;
}

.brand-icon {
    color: #22c55e !important;
    font-size: 1.4rem;
    line-height: 1;
}

.brand-text {
    line-height: 1.2;
}

.brand-text .text-primary {
    color: #1e40af !important;
}

/* === NAVEGACIÓN === */
.nav-link-custom {
    color: #4a5568 !important;
    font-weight: 500;
    padding: 0.5rem 1rem !important;
    border-radius: 8px;
    transition: color 0.2s ease, background-color 0.2s ease;
        position: relative;
        display: flex !important;
        align-items: center;
    white-space: nowrap;
    min-height: 40px;
}

.nav-link-custom:hover {
    color: #1e40af !important;
    background: rgba(30, 64, 175, 0.1);
}

.nav-link-custom i {
    font-size: 1rem !important;
    width: 1.2rem;
    text-align: center;
    flex-shrink: 0;
}

/* === DROPDOWNS === */
.dropdown-menu-custom {
    border: none;
    border-radius: 12px;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    padding: 0.5rem 0;
}

.dropdown-item-custom {
    color: #4a5568 !important;
    font-weight: 500;
    padding: 0.5rem 1rem;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
}

.dropdown-item-custom:hover {
    background: rgba(30, 64, 175, 0.1) !important;
    color: #1e40af !important;
}

.user-dropdown {
    color: #4a5568 !important;
    font-weight: 500;
    text-decoration: none;
}

.user-dropdown:hover {
    color: #1e40af !important;
}

/* === BOTONES DE AUTENTICACIÓN CON ANIMACIÓN DE BARRIDO === */
.btn-auth {
    position: relative;
    overflow: hidden;
    border: 2px solid transparent;
    border-radius: 8px;
    font-weight: 600;
    padding: 0.5rem 1.2rem !important;
    transition: background-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    z-index: 1;
    white-space: nowrap;
    min-height: 40px !important;
    font-size: 0.875rem !important;
    line-height: 1.5;
    }
    
    .btn-register {
    background: #0f172a;
    color: white !important;
    border-color: #0f172a;
}

.btn-login {
    background: transparent;
    color: #0f172a !important;
    border-color: #0f172a;
}

.btn-auth i {
    font-size: 0.875rem !important;
    width: 1rem;
    text-align: center;
    flex-shrink: 0;
}

.btn-auth span {
    flex-shrink: 0;
}

/* Elemento de barrido */
    .btn-sweep {
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
