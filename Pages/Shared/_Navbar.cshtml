<script>
document.addEventListener('DOMContentLoaded', function() {
    // Funcionalidad del botón de tema
    const themeToggle = document.getElementById('themeToggle');
    const themeToggleMobile = document.getElementById('themeToggleMobile');
    
    function toggleTheme() {
        const html = document.documentElement;
        const currentTheme = html.getAttribute('data-bs-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        
        html.setAttribute('data-bs-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        
        // Actualizar iconos
        updateThemeIcons(newTheme);
    }
    
    function updateThemeIcons(theme) {
        const sunIcons = document.querySelectorAll('.theme-icon-sun');
        const moonIcons = document.querySelectorAll('.theme-icon-moon');
        
        if (theme === 'dark') {
            sunIcons.forEach(icon => icon.classList.add('d-none'));
            moonIcons.forEach(icon => icon.classList.remove('d-none'));
        } else {
            sunIcons.forEach(icon => icon.classList.remove('d-none'));
            moonIcons.forEach(icon => icon.classList.add('d-none'));
        }
    }
    
    // Event listeners
    if (themeToggle) {
        themeToggle.addEventListener('click', toggleTheme);
    }
    if (themeToggleMobile) {
        themeToggleMobile.addEventListener('click', toggleTheme);
    }
    
    // Funcionalidad de la hamburguesa animada
    const hamburger = document.querySelector('.custom-hamburger');
    const navbarCollapse = document.querySelector('#navbarContent');
    
    if (hamburger && navbarCollapse) {
        // Inicializar estado
        hamburger.classList.add('collapsed');
        
        // Escuchar eventos de Bootstrap collapse
        navbarCollapse.addEventListener('show.bs.collapse', function () {
            hamburger.classList.remove('collapsed');
        });
        
        navbarCollapse.addEventListener('hide.bs.collapse', function () {
            hamburger.classList.add('collapsed');
        });
        
        // También manejar click directo en la hamburguesa
        hamburger.addEventListener('click', function() {
            // Pequeño delay para sincronizar con Bootstrap
            setTimeout(() => {
                if (navbarCollapse.classList.contains('show')) {
                    hamburger.classList.remove('collapsed');
                } else {
                    hamburger.classList.add('collapsed');
                }
            }, 10);
        });
    }
    
    // Inicializar tema
    const savedTheme = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-bs-theme', savedTheme);
    updateThemeIcons(savedTheme);
});
</script>